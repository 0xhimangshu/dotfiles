[global]
    monitor = 0
    follow = mouse
    width = (300, 800)
    height = 300
    offset = 10x50
    origin = top-right
    scale = 0
    transparency = 5
    padding = 16
    horizontal_padding = 12
    frame_width = 1
    frame_color = "#ffffff"
    separator_color = "auto"
    separator_height = 2
    corner_radius = 16
    progress_bar = true
    progress_bar_height = 6
    progress_bar_frame_width = 0
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    sort = yes
    indicate_hidden = yes
    alignment = left
    show_age_threshold = 60
    word_wrap = yes
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    startup_notification = false
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    icon_theme = "Tela-circle-dracula"
    dmenu = /usr/bin/rofi -config "/home/himonshuuu/.config/rofi/notification.rasi" -dmenu -p "dunst:"
    browser = /usr/bin/firefox
    always_run_script = true
    title = "Dunst Notification"
    class = "Dunst"
    markup = full
    format = "<b>%s</b>\n%b"
    mouse_left_click = context
    mouse_middle_click = do_action
    mouse_right_click = close_all

[urgency_low]
    timeout = 4
    background = "#282a36"
    foreground = "#f8f8f2"
    highlight = "#50fa7b"
    frame_color = "#6272a4"

[urgency_normal]
    timeout = 6
    background = "#44475a"
    foreground = "#f8f8f2"
    highlight = "#ffb86c"
    frame_color = "#ff79c6"

[urgency_critical]
    timeout = 0
    background = "#ff5555"
    foreground = "#ffffff"
    highlight = "#ffb86c"
    frame_color = "#ffb86c"
    underline_color = "#ffb86c"
    bold = true